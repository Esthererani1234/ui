{
  "rewrites": [
    { "source": "/", "destination": "/api/site" },
    { "source": "/index.html", "destination": "/api/site" }
  ],
  "headers": [
    {
      "source": "/api/metals",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=30, stale-while-revalidate=60" }
      ]
    }
  ]
}
