{
  "rewrites": [
    { "source": "/", "destination": "/live.html" },
    { "source": "/index.html", "destination": "/live.html" }
  ],
  "headers": [
    {
      "source": "/api/prices",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=55, stale-while-revalidate=300" }
      ]
    }
  ]
}
